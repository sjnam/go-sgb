% go-sgb: Knuth의 Stanford GraphBase를 한글 GWEB로 옮긴 것.
% 이 파일은 take_risc.w를 Go로 이식한다.
@i ../../gbtypes.w

\input kotexgweb
\def\title{TAKE\_\,RISC}
\def\<#1>{$\langle${\rm#1}$\rangle$}

@* 들어가며. 이 시연 프로그램은 {\sc GB\_\,GATES}의 |Risc| 프로시저가 지은
게이트 그래프를 써서, 작은 수를 느린 방식으로 --- 논리 회로의 동작을 게이트
하나하나 흉내 내어 --- 곱하고 나눈다.

명령줄에서 \.{take\_risc} \<추적>이라 부르되, 기계의 셈 과정을 낱낱이
찍어 보고 싶으면 \<추적>을 비지 않게 준다. 프로그램은 두 수를 물어본 뒤
흉내 낸 RISC 기계로 그 곱과 몫을 셈하고, 다시 두 수를 물어보기를 되풀이한다.
입력은 \UNIX/ 관례를 따라 표준 입력에서 읽는다.

@ 뒤에 나오는 프로그램은 16비트 낱말 서른네 개를 16진수로 적어 놓은 것이라,
{\sc GB\_\,GATES}가 규정한 명령어 형식을 알아야 읽을 수 있다. 여기 간추려
둔다. 낱말 하나는 다섯 마당으로 나뉜다.
$$\vbox{\halign{\indent#\hfil&\quad#\hfil\cr
비트 15--12&\.{DST}---목적지 레지스터 번호\cr
비트 11--8&\.{MOD}---연산의 갈래\cr
비트 7--6&\.{OP}---연산 종류\cr
비트 5--4&\.A---원본(source)을 얻는 방식\cr
비트 3--0&\.{SRC}---원본 지정\cr}}$$
\.A가 0이면 원본은 \.{SRC}를 $-8$부터 $+7$까지의 부호 있는 4비트 수로 읽은
값이고, 1이면 레지스터 \.{DST}의 내용에 그 값을 더한 것, 2이면 레지스터
\.{SRC}의 내용, 3이면 레지스터 \.{SRC}가 가리키는 메모리 낱말이다. 다만
$\.A=3$이고 $\.{SRC}=0$일 때는 특별해서, 레지스터 0이 지금 명령어를 가리키므로
기계는 {\sl 그다음\/} 낱말을 16비트 즉시값으로 쓰고 레지스터 0을 2만큼 늘린다.

@ \.{OP}가 0이면 일반 논리 연산이다. \.{MOD}의 네 비트를 왼쪽부터
$\mu_{11}\mu_{10}\mu_{01}\mu_{00}$이라 할 때, 목적지의 $k$번째 비트가 $i$이고
원본의 $k$번째 비트가 $j$이면 목적지 비트는 $\mu_{ij}$가 된다. 그래서
$\.{MOD}=1010$이면 단순 복사, $0110$이면 배타적 논리합, $0000$이면 $0$으로
지우기다.

\.{OP}가 1이면 산술이다. $\.{MOD}=0$은 왼쪽 1비트 자리이동, $4$는 오른쪽 1비트,
$5$는 부호 없는 오른쪽 1비트, $8$은 덧셈, $10$은 뺄셈, $15$는 \.{JUMP}다.
\.{JUMP}는 원본을 레지스터 0에 옮기고, $\.{DST}\ne0$이면 레지스터 \.{DST}에
다음 명령어의 자리를 넣는다---서브루틴 호출이다.

\.{OP}가 2와 3이면 조건부 적재다. 2는 상태 비트 \.S(부호)와 \.N($0$이 아님)을,
3은 \.K(자리올림)와 \.V(넘침)를 본다. \.{MOD}의 $\mu_{ij}$가 1일 때만 적재하되
$i$와 $j$는 그 두 상태 비트의 현재 값이다. $\.{MOD}=1111$이면 늘 적재하므로,
상태 비트를 건드리지 않고 값을 옮기는 방법이 된다.

@ 이만하면 아래 프로그램을 손으로 풀어 볼 수 있다. 넷만 짚어 보자.

\.{0x2ff0}은 $\.{DST}=2$, $\.{MOD}=1111$, $\.{OP}=3$, $\.A=3$, $\.{SRC}=0$
이다. 늘 적재하고 원본은 다음 낱말이니, \.{r2}에 그 낱말을 넣는다.

\.{0x0f8f}은 $\.{DST}=0$, $\.{MOD}=1111$, $\.{OP}=2$, $\.A=0$, $\.{SRC}=15$
이다. $-1$을 \.{r0}에 넣는 것이니 곧 멈춤이다.

\.{0x0a12}는 $\.{DST}=0$, $\.{MOD}=1010$, $\.{OP}=0$, $\.A=1$, $\.{SRC}=2$
이다. \.{r0}에 \.{r0}${}+2$를 복사하니 한 명령을 건너뛴다.

\.{0x6ac1}은 $\.{DST}=6$, $\.{MOD}=1010$, $\.{OP}=3$, $\.A=0$, $\.{SRC}=1$
이다. $\mu_{\.K\.V}$가 1인 때, 곧 넘침일 때만 \.{r6}에 1을 넣는다.

자세한 것은 {\sc GB\_\,GATES}의 설명을 보라.

@ 프로그램의 뼈대다. |Risc(8)|은 레지스터 여덟 개짜리 기계를 짓고,
추적할 때는 레지스터 0--7을 보인다.

@c
package main

import (
	"bufio"
	"fmt"
	"os"
	@#
	"github.com/sjnam/go-sgb/gbgates"
)

const (
	mult = 10 // 아래 프로그램에서 곱셈 진입점 위치
	div  = 7  // 아래 프로그램에서 나눗셈 진입점 위치
)

@<입력받기 서브루틴@>

func main() {
	var trace int64
	if len(os.Args) > 1 {
		trace = 8 // 추적하면 레지스터 0--7을 보인다
	}
	g, err := gbgates.Risc(8)
	if err != nil {
		fmt.Printf("Sorry, I couldn't generate the graph (trouble code %v)!\n", err)
		os.Exit(1)
	}
	fmt.Println("Welcome to the world of microRISC.")
	@<읽기 전용 메모리를 잡는다@>
	in := bufio.NewReader(os.Stdin)
	for {
		m, ok := getNumber(in, "\nGimme a number: ")
		if !ok {
			break
		}
		n, ok := getNumber(in, "OK, now gimme another: ")
		if !ok {
			break
		}
		@<RISC 기계로 곱 |p|를 셈한다@>
		fmt.Printf("The product of %d and %d is %d%s.\n", m, n, p, ovStr)
		@<RISC 기계로 몫 |q|와 나머지 |r|를 셈한다@>
		fmt.Printf("The quotient is %d, and the remainder is %d.\n", q, r)
	}
}

@ 두 수를 물어보는 대목이다. \CEE/ 원본은 |goto|로 얽힌 작은 상태 기계였는데,
여기서는 중첩 반복문으로 옮긴다. |getNumber|는 프롬프트를 찍고 한 줄을 읽어 그
줄에서 정수를 뽑는다. 파일 끝이거나 정수가 아니면 거짓을 돌려주고, 0 이하이면
한 번 더 채근하고, $2^{15}$ 이상이면 될 때까지 다시 묻는다 --- 다만 그 사이
0 이하가 나오면 양수 확인 단계로 되돌아간다.
@<입력받기 서브루틴@>=
func readInt(in *bufio.Reader, prompt string) (int64, bool) {
	fmt.Print(prompt)
	line, err := in.ReadString('\n')
	if err != nil && line == "" {
		return 0, false // 아무것도 못 읽은 파일 끝
	}
	var m int64
	if k, _ := fmt.Sscanf(line, "%d", &m); k != 1 {
		return 0, false // 정수가 아니다
	}
	return m, true
}

@ |readInt|이 거짓을 돌려주면 (파일 끝이든 파싱 실패든) 어느 자리에서나
그만두므로, 두 경우를 한 불리언으로 합쳐 다룬다.
@<입력받기 서브루틴@>=
func getNumber(in *bufio.Reader, firstPrompt string) (int64, bool) {
	m, ok := readInt(in, firstPrompt)
	if !ok {
		return 0, false
	}
	for {
		if m <= 0 {
			m, ok = readInt(in, "Excuse me, I meant a positive number: ")
			if !ok || m <= 0 {
				return 0, false
			}
		}
		for m > 0x7fff {
			m, ok = readInt(in, "That number's too big; please try again: ")
			if !ok {
				return 0, false
			}
			if m <= 0 {
				break // 양수 확인 단계로 되돌아간다
			}
		}
		if m > 0 && m <= 0x7fff {
			return m, true
		}
	}
}

@* RISC 프로그램. 작은 컴퓨터에 돌릴 작은 프로그램이다. 핵심은 삼항 연산
$x\lfloor y/z\rfloor$을 셈하는 |tri| 서브루틴으로, $y\ge0$, $z>0$을 가정한다.
입력 $x,y,z$는 각각 레지스터 1, 2, 3에 있고, 복귀 주소는 레지스터 7에 있다고
본다. 특수한 경우로 $z=1$이면 곱 $xy$를, $x=1$이면 몫 $\lfloor y/z\rfloor$을
얻는다. 서브루틴이 돌아올 때 결과는 레지스터 4에, $(y\bmod z)-z$ 값은 레지스터
2에 남는다. 참값이 $-2^{15}$과 $2^{15}-1$ 사이(양끝 포함)에 없을 때만 넘침이
켜진다.

부호 없는 16비트 수로 돌아가게 고치거나, 32비트나 48비트, 어쩌면 64비트
정밀도로 결과를 내게 고치는 것도 그리 어렵지 않을 것이다.

@ |tri|가 어떻게 돌아가는지는 원본도 밝히지 않았으니, 여기서 풀어 두자.
두 판으로 나뉜다.

{\bf 첫째 판(|l1|--|l2|).} \.{r3}을 $z$에서 시작해 거듭 두 배로 키우고,
\.{r1}은 $x$에서 시작해 나란히 두 배로 키우며, \.{r5}로 그 횟수를 센다.
\.{r2}는 $y$에서 시작해 매번 지금의 \.{r3}을 빼므로, $k$번 두 배가 된 뒤에는
$$\.{r3}=2^kz,\qquad \.{r1}=2^kx,\qquad \.{r5}=k,\qquad
  \.{r2}=y-z-2z-4z-\cdots-2^kz=y-2^{k+1}z$$
가 된다. 고리는 \.{r2}가 음수가 되는 첫 $k$에서 멈추므로, 그때
$2^kz\le y<2^{k+1}z$다. \.{r1}이 넘치면 \.{r6}에 적어 둔다.

{\bf 둘째 판(|l3|--|l5|).} 이제 \.{r3}과 \.{r1}을 거꾸로 반씩 줄이며
$k+1$번 돈다. 남은 몫을 $R$이라 할 때, |l4| 어귀에서 늘
$$\.{r2}=R-2\cdot\.{r3}$$
이 성립한다는 것이 이 판의 불변식이다. 첫째 판이 끝난 자리에서 $R=y$이고
$\.{r2}=y-2^{k+1}z=y-2\cdot\.{r3}$이니 처음에 참이다.

@ 불변식이 이어짐을 보자. |l4|는 먼저 \.{r2}에 \.{r3}을 더해 $R-\.{r3}$을
만든다. 이것이 음수이면 $R<\.{r3}$이라 이 자리의 몫 비트는 $0$이다. 그냥
|l5|로 가면, \.{r3}이 반으로 줄어 $\.{r3}'=\.{r3}/2$가 되고
$R-\.{r3}=R-2\.{r3}'$이니 불변식이 그대로다.

음수가 아니면 몫 비트가 $1$이다. \.{r4}에 $\.{r1}=x\cdot(\.{r3}/z)$를 더하고,
\.{r2}에서 \.{r3}을 도로 빼 $R-2\.{r3}$으로 돌린다. 새 나머지는
$R'=R-\.{r3}$이므로 $R-2\.{r3}=R'-\.{r3}=R'-2\.{r3}'$---역시 불변식이다.

마지막 바퀴에서는 $\.{r3}=z$이므로, 끝났을 때 \.{r2}는 마지막 나머지에서 $z$를
뺀 값, 곧 $(y\bmod z)-z$가 된다. 명세 그대로다. 그리고 \.{r4}에는 몫의 각 비트마다 $x\cdot2^j$가
더해졌으니 $x\lfloor y/z\rfloor$이다.

@ 자잘하지만 눈여겨볼 것 둘. \.{r1}을 되돌릴 때 쓰는 것은 {\sl 부호 없는\/}
오른쪽 자리이동($\.{MOD}=5$)이다. $2^kx$가 넘쳐 부호 비트를 물들였을 수 있는데,
부호 있는 자리이동은 그 부호를 늘려 엉뚱한 값을 만들기 때문이다. 반면 \.{r3}은
$2^kz\le y<2^{15}$이라 넘칠 일이 없으므로 보통 자리이동($\.{MOD}=4$)을 쓴다.

또 넘침은 곧바로 \.V에 남기지 않고 \.{r6}에 모아 둔다. 중간의 다른 연산이
\.V를 덮어쓰기 때문이다. 맨 끝의 |0x6666|이 \.{r6}을 오른쪽으로 4비트 밀어
그 안의 1을 잃어버리게 함으로써 \.V를 억지로 켠다.

@ 이 읽기 전용 메모리는 |RunRisc|가 흉내 낼 34낱말짜리 프로그램이다. 셈할 때마다
|rom[1]|에 |m|을, |rom[3]|에 |n|을, |rom[5]|에 |mult|나 |div|를 채워 넣는다.
그래서 전역이 아니라 |main| 안의 지역 슬라이스로 둔다.
@<읽기 전용 메모리를 잡는다@>=
rom := []int64{
	0x2ff0, // |start|: |r2| = m (다음 낱말의 내용)
	0x1111, // (|rom[1]|에 |m| 값을 넣는다)
	0x1a30, // |r1| = n (다음 낱말의 내용)
	0x3333, // (|rom[3]|에 |n| 값을 넣는다)
	0x7f70, // 다음 낱말로 뛰고 |r7| = 복귀 주소
	0x5555, // (|rom[5]|에 |mult|나 |div|를 넣는다)
	0x0f8f, // 상태 비트를 안 바꾸고 멈춘다
	0x3a21, // |div|: |r3 = r1|
	0x1a01, // |r1 = 1|
	0x0a12, // |tri|로 간다 (곧, |r0 += 2|)
	0x3a01, // |mult|: |r3 = 1|
	0x4000, // |tri|: |r4 = 0|
	0x5000, // |r5 = 0|
	0x6000, // |r6 = 0|
	0x2a63, // |r2 -= r3|
	0x0f95, // |l2|로 간다
	0x3063, // |l1|: |r3 <<= 1|
	0x1061, // |r1 <<= 1|
	0x6ac1, // 넘침이면 |r6 = 1|
	0x5fd1, // |r5++|
	0x2a63, // |l2|: |r2 -= r3|
	0x039b, // 0 이상이면 |l1|로 간다
	0x0843, // |l4|로 간다
	0x3463, // |l3|: |r3 >>= 1|
	0x1561, // |r1 >>= 1|
	0x2863, // |l4|: |r2 += r3|
	0x0c94, // 음수면 |l5|로 간다
	0x4861, // |r4 += r1|
	0x6ac1, // 넘침이면 |r6 = 1|
	0x2a63, // |r2 -= r3|
	0x5a41, // |l5|: |r5--|
	0x0398, // 0 이상이면 |l3|로 간다
	0x6666, // |r6|면 넘침을 강제한다 (곧, |r6 >>= 4|)
	0x0fa7, // 돌아간다 (곧, |r0 = r7|, 넘침 보존)
}

@ 곱을 셈한다. |RunRisc|는 기계를 지우고 주소 0에서 시작해, 낱말 열여덟 개짜리
배열을 돌려준다. |st[0]|부터 |st[15]|까지가 레지스터 $0$--$15$이고, |st[16]|은
프로그램 레지스터와 네 상태 비트를, |st[17]|은 마지막으로 읽은 메모리 주소를
담는다. 넘침 비트 \.V는 |st[16]|의 최하위 비트다. 결과는 레지스터 4에 있다.
@<RISC 기계로 곱 |p|를 셈한다@>=
rom[1] = m
rom[3] = n
rom[5] = mult
st, _ := gbgates.RunRisc(g, rom, trace, os.Stdout)
p := st[4]
ovStr := ""
if st[16]&1 != 0 {
	ovStr = " (overflow occurred)"
}

@ 몫과 나머지를 셈한다. 나머지는 $(y\bmod z)-z$에서 되살린다.
@<RISC 기계로 몫 |q|와 나머지 |r|를 셈한다@>=
rom[5] = div
st, _ = gbgates.RunRisc(g, rom, trace, os.Stdout)
q := st[4]
r := (st[2] + n) & 0x7fff

@* 색인.
